{
  "expo": {
    "name": "ChaloPB",
    "slug": "chalopb-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobileapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermissions": "Allow ChaloPB to access your location to track buses."
        }
      ]
    ],
    "extra": {
      "apiUrl": {
        "web": "http://localhost:5000/api",
        "androidEmulator": "http://10.0.2.2:5000/api",
        "androidDevice": "http://172.20.10.3:5000/api",
        "default": "http://localhost:5000/api"
      },
      "socketUrl": {
        "web": "http://localhost:5000",
        "androidEmulator": "http://10.0.2.2:5000",
        "androidDevice": "http://172.20.10.3:5000",
        "default": "http://localhost:5000"
      },
      "appName": "ChaloPB"
    }
  }
}
